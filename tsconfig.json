{
  "compilerOptions": {
    "target": "es6",
    "module": "nodenext",
    "moduleResolution": "node16",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "allowJs": true,
    "types": ["node", "express", "multer"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
