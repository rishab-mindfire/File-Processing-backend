{

  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "target": "es2021",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "allowJs": true,
    "types": ["node", "express", "multer"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"],
  "ts-node": {
    "esm": true,
    "experimentalSpecifiers": true
  }
}
